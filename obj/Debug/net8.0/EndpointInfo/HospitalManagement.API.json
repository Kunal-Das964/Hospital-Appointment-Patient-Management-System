  "components": {
    "schemas": {
      "BookAppointmentDto": {
        "required": [
          "appointmentDate",
          "doctorId",
          "patientId"
        ],
        "type": "object",
        "properties": {
          "patientId": {
            "type": "integer",
            "format": "int32"
          },
          "doctorId": {
            "type": "integer",
            "format": "int32"
          },
          "appointmentDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "CreatePatientDto": {
        "required": [
          "dateOfBirth",
          "fullName",
          "gender",
          "patientCode",
          "phoneNumber"
        ],
        "type": "object",
        "properties": {
          "patientCode": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string"
          },
          "fullName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date-time"
          },
          "gender": {
            "pattern": "^[MFO]$",
            "type": "string"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string",
            "format": "tel"
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdatePatientDto": {
        "required": [
          "fullName",
          "phoneNumber"
        ],
        "type": "object",
        "properties": {
          "fullName": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string",
            "format": "tel"
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
